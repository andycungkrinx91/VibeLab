AI_PROVIDER=gemini
AI_DISABLE_THINKING=false

# Gemini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_CHEAP_MODEL=gemini-2.5-flash-lite

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
OPENAI_CHEAP_MODEL=

# OpenAI-compatible
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_TEXT_MODEL=
OPENAI_COMPAT_CHEAP_MODEL=
OPENAI_COMPAT_PROVIDER_LABEL=

# Cloudflare Workers AI example:
# AI_PROVIDER=openai-compatible
# OPENAI_COMPAT_PROVIDER_LABEL=Cloudflare Workers AI
# OPENAI_COMPAT_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1
# OPENAI_COMPAT_TEXT_MODEL=@cf/openai/gpt-oss-120b

# Local LLM / Ollama example:
# AI_PROVIDER=openai-compatible
# OPENAI_COMPAT_PROVIDER_LABEL=Local LLM
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=local
# OPENAI_COMPAT_TEXT_MODEL=llama3.1
